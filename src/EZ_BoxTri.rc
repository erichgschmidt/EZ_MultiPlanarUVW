// EZ_BoxTri rollout  —  108 DU wide
//
// 4 layer groups (74 DU each) + Blend Math group + Output group.
//
// Layer block (inside group, relative y):
//   y+12: [x]Enable  Ch:[spin]  [Type combo]
//   y+26: UT:[spin]   VT:[spin]
//   y+40: UO:[spin]   VO:[spin]
//   y+54: [x]FlipU    [x]FlipV
//
// Group y positions (absolute):
//   Wall X:   y=2,   h=74    bottom=76
//   Wall Y:   y=80,  h=74    bottom=154
//   Floor:    y=158, h=74    bottom=232
//   Ceiling:  y=236, h=74    bottom=310
//   Blend:    y=316, h=98    bottom=414
//   Output:   y=420, h=82    bottom=502

#include <winresrc.h>
#include "resource.h"

LANGUAGE LANG_NEUTRAL, SUBLANG_NEUTRAL

STRINGTABLE
BEGIN
    IDS_PARAMS        "Parameters"

    IDS_EN1   "EnableX"   IDS_CH1  "ChX"   IDS_TYPE1 "TypeX"
    IDS_UT1   "UTileX"    IDS_VT1  "VTileX"
    IDS_UOFF1 "UOffX"     IDS_VOFF1 "VOffX"
    IDS_FLIPU1 "FlipUX"   IDS_FLIPV1 "FlipVX"

    IDS_EN2   "EnableY"   IDS_CH2  "ChY"   IDS_TYPE2 "TypeY"
    IDS_UT2   "UTileY"    IDS_VT2  "VTileY"
    IDS_UOFF2 "UOffY"     IDS_VOFF2 "VOffY"
    IDS_FLIPU2 "FlipUY"   IDS_FLIPV2 "FlipVY"

    IDS_EN3   "EnableF"   IDS_CH3  "ChF"   IDS_TYPE3 "TypeF"
    IDS_UT3   "UTileF"    IDS_VT3  "VTileF"
    IDS_UOFF3 "UOffF"     IDS_VOFF3 "VOffF"
    IDS_FLIPU3 "FlipUF"   IDS_FLIPV3 "FlipVF"

    IDS_EN4   "EnableC"   IDS_CH4  "ChC"   IDS_TYPE4 "TypeC"
    IDS_UT4   "UTileC"    IDS_VT4  "VTileC"
    IDS_UOFF4 "UOffC"     IDS_VOFF4 "VOffC"
    IDS_FLIPU4 "FlipUC"   IDS_FLIPV4 "FlipVC"

    IDS_SHARP        "Sharp"
    IDS_INVERTZ      "InvertZ"
    IDS_WALLXBIAS    "WallXBias"
    IDS_WALLYBIAS    "WallYBias"
    IDS_FLOORBIAS    "FloorBias"
    IDS_CEILBIAS     "CeilingBias"
    IDS_FLOORSTART   "FloorStart"
    IDS_CEILSTART    "CeilingStart"
    IDS_HARDDOM      "HardDominant"
    IDS_HARDTHRESH   "HardThreshold"

    IDS_BLENDCH      "BlendChannel"
    IDS_PREVIEWCH    "PreviewChannel"
    IDS_PREVIEWMODE  "PreviewMode"
    IDS_SIGNEDFIX    "SignedAxisFix"
    IDS_WRITEPREVIEW "WritePreview"
END

IDD_PANEL DIALOG 0, 0, 108, 516
STYLE DS_SETFONT | WS_CHILD | WS_VISIBLE
FONT 8, "MS Sans Serif"
BEGIN
    // ============================================================  WALL X  y=2
    GROUPBOX "Side X", IDC_STATIC, 2, 2, 104, 74
    CONTROL  "En",  IDC_CHK_EN_1,    "Button",BS_AUTOCHECKBOX|WS_GROUP|WS_TABSTOP,  6,14, 18,10
    LTEXT    "Ch:", IDC_STATIC,                                                     26,14, 12,10
    CONTROL  "",    IDC_EDIT_CH_1,   "CustEdit",       WS_TABSTOP,                  38,13, 14,12
    CONTROL  "",    IDC_SPIN_CH_1,   "SpinnerControl", WS_TABSTOP,                  52,13,  7,12
    COMBOBOX        IDC_COMBO_TYPE_1,                                                62,13, 40,80, CBS_DROPDOWNLIST|WS_TABSTOP
    LTEXT    "UT:", IDC_STATIC,                                                      6,28, 12,10
    CONTROL  "",    IDC_EDIT_UT_1,   "CustEdit",       WS_TABSTOP,                  18,27, 22,12
    CONTROL  "",    IDC_SPIN_UT_1,   "SpinnerControl", WS_TABSTOP,                  40,27,  7,12
    LTEXT    "VT:", IDC_STATIC,                                                     52,28, 12,10
    CONTROL  "",    IDC_EDIT_VT_1,   "CustEdit",       WS_TABSTOP,                  64,27, 22,12
    CONTROL  "",    IDC_SPIN_VT_1,   "SpinnerControl", WS_TABSTOP,                  86,27,  7,12
    LTEXT    "UO:", IDC_STATIC,                                                      6,42, 12,10
    CONTROL  "",    IDC_EDIT_UOFF_1, "CustEdit",       WS_TABSTOP,                  18,41, 22,12
    CONTROL  "",    IDC_SPIN_UOFF_1, "SpinnerControl", WS_TABSTOP,                  40,41,  7,12
    LTEXT    "VO:", IDC_STATIC,                                                     52,42, 12,10
    CONTROL  "",    IDC_EDIT_VOFF_1, "CustEdit",       WS_TABSTOP,                  64,41, 22,12
    CONTROL  "",    IDC_SPIN_VOFF_1, "SpinnerControl", WS_TABSTOP,                  86,41,  7,12
    CONTROL  "Flip U", IDC_CHK_FLIPU_1,"Button",BS_AUTOCHECKBOX|WS_GROUP|WS_TABSTOP, 6,58, 32,10
    CONTROL  "Flip V", IDC_CHK_FLIPV_1,"Button",BS_AUTOCHECKBOX|WS_TABSTOP,         44,58, 32,10

    // ============================================================  WALL Y  y=80
    GROUPBOX "Side Y", IDC_STATIC, 2, 80, 104, 74
    CONTROL  "En",  IDC_CHK_EN_2,    "Button",BS_AUTOCHECKBOX|WS_GROUP|WS_TABSTOP,  6,92, 18,10
    LTEXT    "Ch:", IDC_STATIC,                                                     26,92, 12,10
    CONTROL  "",    IDC_EDIT_CH_2,   "CustEdit",       WS_TABSTOP,                  38,91, 14,12
    CONTROL  "",    IDC_SPIN_CH_2,   "SpinnerControl", WS_TABSTOP,                  52,91,  7,12
    COMBOBOX        IDC_COMBO_TYPE_2,                                                62,91, 40,80, CBS_DROPDOWNLIST|WS_TABSTOP
    LTEXT    "UT:", IDC_STATIC,                                                      6,106,12,10
    CONTROL  "",    IDC_EDIT_UT_2,   "CustEdit",       WS_TABSTOP,                  18,105,22,12
    CONTROL  "",    IDC_SPIN_UT_2,   "SpinnerControl", WS_TABSTOP,                  40,105, 7,12
    LTEXT    "VT:", IDC_STATIC,                                                     52,106,12,10
    CONTROL  "",    IDC_EDIT_VT_2,   "CustEdit",       WS_TABSTOP,                  64,105,22,12
    CONTROL  "",    IDC_SPIN_VT_2,   "SpinnerControl", WS_TABSTOP,                  86,105, 7,12
    LTEXT    "UO:", IDC_STATIC,                                                      6,120,12,10
    CONTROL  "",    IDC_EDIT_UOFF_2, "CustEdit",       WS_TABSTOP,                  18,119,22,12
    CONTROL  "",    IDC_SPIN_UOFF_2, "SpinnerControl", WS_TABSTOP,                  40,119, 7,12
    LTEXT    "VO:", IDC_STATIC,                                                     52,120,12,10
    CONTROL  "",    IDC_EDIT_VOFF_2, "CustEdit",       WS_TABSTOP,                  64,119,22,12
    CONTROL  "",    IDC_SPIN_VOFF_2, "SpinnerControl", WS_TABSTOP,                  86,119, 7,12
    CONTROL  "Flip U", IDC_CHK_FLIPU_2,"Button",BS_AUTOCHECKBOX|WS_GROUP|WS_TABSTOP, 6,136,32,10
    CONTROL  "Flip V", IDC_CHK_FLIPV_2,"Button",BS_AUTOCHECKBOX|WS_TABSTOP,         44,136,32,10

    // ============================================================  FLOOR  y=158
    GROUPBOX "Top (+Z)", IDC_STATIC, 2, 158, 104, 74
    CONTROL  "En",  IDC_CHK_EN_3,    "Button",BS_AUTOCHECKBOX|WS_GROUP|WS_TABSTOP,  6,170,18,10
    LTEXT    "Ch:", IDC_STATIC,                                                     26,170,12,10
    CONTROL  "",    IDC_EDIT_CH_3,   "CustEdit",       WS_TABSTOP,                  38,169,14,12
    CONTROL  "",    IDC_SPIN_CH_3,   "SpinnerControl", WS_TABSTOP,                  52,169, 7,12
    COMBOBOX        IDC_COMBO_TYPE_3,                                                62,169,40,80, CBS_DROPDOWNLIST|WS_TABSTOP
    LTEXT    "UT:", IDC_STATIC,                                                      6,184,12,10
    CONTROL  "",    IDC_EDIT_UT_3,   "CustEdit",       WS_TABSTOP,                  18,183,22,12
    CONTROL  "",    IDC_SPIN_UT_3,   "SpinnerControl", WS_TABSTOP,                  40,183, 7,12
    LTEXT    "VT:", IDC_STATIC,                                                     52,184,12,10
    CONTROL  "",    IDC_EDIT_VT_3,   "CustEdit",       WS_TABSTOP,                  64,183,22,12
    CONTROL  "",    IDC_SPIN_VT_3,   "SpinnerControl", WS_TABSTOP,                  86,183, 7,12
    LTEXT    "UO:", IDC_STATIC,                                                      6,198,12,10
    CONTROL  "",    IDC_EDIT_UOFF_3, "CustEdit",       WS_TABSTOP,                  18,197,22,12
    CONTROL  "",    IDC_SPIN_UOFF_3, "SpinnerControl", WS_TABSTOP,                  40,197, 7,12
    LTEXT    "VO:", IDC_STATIC,                                                     52,198,12,10
    CONTROL  "",    IDC_EDIT_VOFF_3, "CustEdit",       WS_TABSTOP,                  64,197,22,12
    CONTROL  "",    IDC_SPIN_VOFF_3, "SpinnerControl", WS_TABSTOP,                  86,197, 7,12
    CONTROL  "Flip U", IDC_CHK_FLIPU_3,"Button",BS_AUTOCHECKBOX|WS_GROUP|WS_TABSTOP, 6,214,32,10
    CONTROL  "Flip V", IDC_CHK_FLIPV_3,"Button",BS_AUTOCHECKBOX|WS_TABSTOP,         44,214,32,10

    // ============================================================  CEILING  y=236
    GROUPBOX "Bottom (-Z)", IDC_STATIC, 2, 236, 104, 74
    CONTROL  "En",  IDC_CHK_EN_4,    "Button",BS_AUTOCHECKBOX|WS_GROUP|WS_TABSTOP,  6,248,18,10
    LTEXT    "Ch:", IDC_STATIC,                                                     26,248,12,10
    CONTROL  "",    IDC_EDIT_CH_4,   "CustEdit",       WS_TABSTOP,                  38,247,14,12
    CONTROL  "",    IDC_SPIN_CH_4,   "SpinnerControl", WS_TABSTOP,                  52,247, 7,12
    COMBOBOX        IDC_COMBO_TYPE_4,                                                62,247,40,80, CBS_DROPDOWNLIST|WS_TABSTOP
    LTEXT    "UT:", IDC_STATIC,                                                      6,262,12,10
    CONTROL  "",    IDC_EDIT_UT_4,   "CustEdit",       WS_TABSTOP,                  18,261,22,12
    CONTROL  "",    IDC_SPIN_UT_4,   "SpinnerControl", WS_TABSTOP,                  40,261, 7,12
    LTEXT    "VT:", IDC_STATIC,                                                     52,262,12,10
    CONTROL  "",    IDC_EDIT_VT_4,   "CustEdit",       WS_TABSTOP,                  64,261,22,12
    CONTROL  "",    IDC_SPIN_VT_4,   "SpinnerControl", WS_TABSTOP,                  86,261, 7,12
    LTEXT    "UO:", IDC_STATIC,                                                      6,276,12,10
    CONTROL  "",    IDC_EDIT_UOFF_4, "CustEdit",       WS_TABSTOP,                  18,275,22,12
    CONTROL  "",    IDC_SPIN_UOFF_4, "SpinnerControl", WS_TABSTOP,                  40,275, 7,12
    LTEXT    "VO:", IDC_STATIC,                                                     52,276,12,10
    CONTROL  "",    IDC_EDIT_VOFF_4, "CustEdit",       WS_TABSTOP,                  64,275,22,12
    CONTROL  "",    IDC_SPIN_VOFF_4, "SpinnerControl", WS_TABSTOP,                  86,275, 7,12
    CONTROL  "Flip U", IDC_CHK_FLIPU_4,"Button",BS_AUTOCHECKBOX|WS_GROUP|WS_TABSTOP, 6,292,32,10
    CONTROL  "Flip V", IDC_CHK_FLIPV_4,"Button",BS_AUTOCHECKBOX|WS_TABSTOP,         44,292,32,10

    // ============================================================  BLEND MATH  y=316
    GROUPBOX "Blend Math", IDC_STATIC, 2, 316, 104, 98
    LTEXT    "Sharp:",   IDC_STATIC,                                                 6,328,26,10
    CONTROL  "",  IDC_EDIT_SHARP,      "CustEdit",       WS_TABSTOP,                34,327,22,12
    CONTROL  "",  IDC_SPIN_SHARP,      "SpinnerControl", WS_TABSTOP,                56,327, 7,12
    LTEXT    "Hard:",    IDC_STATIC,                                                65,328,18,10
    CONTROL  "",  IDC_EDIT_HARDTHRESH, "CustEdit",       WS_TABSTOP,                83,327,16,12
    CONTROL  "",  IDC_SPIN_HARDTHRESH, "SpinnerControl", WS_TABSTOP,                99,327, 7,12

    LTEXT    "X Bias:",  IDC_STATIC,                                                 6,342,26,10
    CONTROL  "",  IDC_EDIT_WALLXBIAS,  "CustEdit",       WS_TABSTOP,                34,341,22,12
    CONTROL  "",  IDC_SPIN_WALLXBIAS,  "SpinnerControl", WS_TABSTOP,                56,341, 7,12
    LTEXT    "Y Bias:",  IDC_STATIC,                                                65,342,26,10
    CONTROL  "",  IDC_EDIT_WALLYBIAS,  "CustEdit",       WS_TABSTOP,                83,341,16,12
    CONTROL  "",  IDC_SPIN_WALLYBIAS,  "SpinnerControl", WS_TABSTOP,                99,341, 7,12

    LTEXT    "Top Bias", IDC_STATIC,                                                 6,356,26,10
    CONTROL  "",  IDC_EDIT_FLOORBIAS,  "CustEdit",       WS_TABSTOP,                34,355,22,12
    CONTROL  "",  IDC_SPIN_FLOORBIAS,  "SpinnerControl", WS_TABSTOP,                56,355, 7,12
    LTEXT    "Bot Bias", IDC_STATIC,                                                65,356,26,10
    CONTROL  "",  IDC_EDIT_CEILBIAS,   "CustEdit",       WS_TABSTOP,                83,355,16,12
    CONTROL  "",  IDC_SPIN_CEILBIAS,   "SpinnerControl", WS_TABSTOP,                99,355, 7,12

    LTEXT    "Top Start",IDC_STATIC,                                                 6,370,30,10
    CONTROL  "",  IDC_EDIT_FLOORSTART, "CustEdit",       WS_TABSTOP,                36,369,20,12
    CONTROL  "",  IDC_SPIN_FLOORSTART, "SpinnerControl", WS_TABSTOP,                56,369, 7,12
    LTEXT    "Bot Start",IDC_STATIC,                                                65,370,30,10
    CONTROL  "",  IDC_EDIT_CEILSTART,  "CustEdit",       WS_TABSTOP,                95,369, 4,12
    CONTROL  "",  IDC_SPIN_CEILSTART,  "SpinnerControl", WS_TABSTOP,                99,369, 7,12

    CONTROL  "Invert Z",    IDC_CHK_INVERTZ, "Button",BS_AUTOCHECKBOX|WS_GROUP|WS_TABSTOP,  6,386,42,10
    CONTROL  "Hard Snap",   IDC_CHK_HARDDOM, "Button",BS_AUTOCHECKBOX|WS_TABSTOP,           54,386,46,10

    // ============================================================  OUTPUT  y=420
    GROUPBOX "Output", IDC_STATIC, 2, 420, 104, 96
    LTEXT    "Blend Ch:",   IDC_STATIC,                                              6,432,32,10
    CONTROL  "",  IDC_EDIT_BLENDCH,   "CustEdit",       WS_TABSTOP,                 40,431,22,12
    CONTROL  "",  IDC_SPIN_BLENDCH,   "SpinnerControl", WS_TABSTOP,                 62,431, 7,12
    LTEXT    "Preview Ch:", IDC_STATIC,                                              6,446,38,10
    CONTROL  "",  IDC_EDIT_PREVIEWCH, "CustEdit",       WS_TABSTOP,                 46,445,22,12
    CONTROL  "",  IDC_SPIN_PREVIEWCH, "SpinnerControl", WS_TABSTOP,                 68,445, 7,12
    LTEXT    "Mode:",       IDC_STATIC,                                              6,460,22,10
    COMBOBOX        IDC_COMBO_PREVMODE,                                              30,459,72,80, CBS_DROPDOWNLIST|WS_TABSTOP
    CONTROL  "Write Preview (vtx colour ch0)", IDC_CHK_WRITEPREVIEW, "Button",BS_AUTOCHECKBOX|WS_GROUP|WS_TABSTOP, 6,476,98,10
    CONTROL  "Signed-Axis Fix",IDC_CHK_SIGNEDFIX, "Button",BS_AUTOCHECKBOX|WS_TABSTOP, 6,490,76,10
END

// ===========================================================================
//  EZ BoxTri AO  (second modifier)
// ===========================================================================

STRINGTABLE
BEGIN
    IDS_AO_PARAMS    "Parameters"
    IDS_AO_CH        "AOChannel"
    IDS_AO_CAVITY    "Cavity"
    IDS_AO_HEIGHT    "Height"
    IDS_AO_DOWN      "Down"
    IDS_AO_STRENGTH  "Strength"
    IDS_AO_GRAY      "Grayscale"
    IDS_AO_PREVIEW   "Preview"
    IDS_AO_INVERT    "Invert"
END

IDD_PANEL_AO DIALOG 0, 0, 108, 98
STYLE DS_SETFONT | WS_CHILD | WS_VISIBLE
FONT 8, "MS Sans Serif"
BEGIN
    GROUPBOX "AO (pseudo, ch 11)", IDC_STATIC, 2, 2, 104, 92
    LTEXT    "Ch:", IDC_STATIC,                                                       6,16,12,10
    CONTROL  "",  IDC_AO_EDIT_CH,      "CustEdit",       WS_TABSTOP,                  20,15,16,12
    CONTROL  "",  IDC_AO_SPIN_CH,      "SpinnerControl", WS_TABSTOP,                  36,15, 7,12
    CONTROL  "Grayscale", IDC_AO_CHK_GRAY, "Button",BS_AUTOCHECKBOX|WS_GROUP|WS_TABSTOP, 50,16,52,10
    LTEXT    "Cavity:", IDC_STATIC,                                                    6,32,28,10
    CONTROL  "",  IDC_AO_EDIT_CAVITY,  "CustEdit",       WS_TABSTOP,                  34,31,22,12
    CONTROL  "",  IDC_AO_SPIN_CAVITY,  "SpinnerControl", WS_TABSTOP,                  56,31, 7,12
    LTEXT    "Height:", IDC_STATIC,                                                   65,32,24,10
    CONTROL  "",  IDC_AO_EDIT_HEIGHT,  "CustEdit",       WS_TABSTOP,                  83,31,16,12
    CONTROL  "",  IDC_AO_SPIN_HEIGHT,  "SpinnerControl", WS_TABSTOP,                  99,31, 7,12
    LTEXT    "Down:", IDC_STATIC,                                                      6,46,28,10
    CONTROL  "",  IDC_AO_EDIT_DOWN,    "CustEdit",       WS_TABSTOP,                  34,45,22,12
    CONTROL  "",  IDC_AO_SPIN_DOWN,    "SpinnerControl", WS_TABSTOP,                  56,45, 7,12
    LTEXT    "Strength:", IDC_STATIC,                                                 65,46,24,10
    CONTROL  "",  IDC_AO_EDIT_STRENGTH,"CustEdit",       WS_TABSTOP,                  83,45,16,12
    CONTROL  "",  IDC_AO_SPIN_STRENGTH,"SpinnerControl", WS_TABSTOP,                  99,45, 7,12
    CONTROL  "Invert (1=occluded)", IDC_AO_CHK_INVERT,  "Button",BS_AUTOCHECKBOX|WS_GROUP|WS_TABSTOP, 6,62,98,10
    CONTROL  "Preview to ch0 (vtx colour)", IDC_AO_CHK_PREVIEW, "Button",BS_AUTOCHECKBOX|WS_TABSTOP, 6,76,98,10
END

// ===========================================================================
//  EZ Procedural Masks  (third modifier)
// ===========================================================================

STRINGTABLE
BEGIN
    IDS_MK_PARAMS    "Parameters"
    IDS_MK_TARGETCH  "TargetChannel"
    IDS_MK_CONTRAST  "Contrast"
    IDS_MK_BLUR      "Blur"
    IDS_MK_INVERTALL "InvertAll"
    IDS_MK_OVERCRANK "Overcrank"
    IDS_MK_PREVIEW   "Preview"
    IDS_MK_SRCR  "SourceR"  IDS_MK_WR  "WeightR"  IDS_MK_INVR "InvertR"
    IDS_MK_SRCG  "SourceG"  IDS_MK_WG  "WeightG"  IDS_MK_INVG "InvertG"
    IDS_MK_SRCB  "SourceB"  IDS_MK_WB  "WeightB"  IDS_MK_INVB "InvertB"
END

IDD_PANEL_MASKS DIALOG 0, 0, 108, 104
STYLE DS_SETFONT | WS_CHILD | WS_VISIBLE
FONT 8, "MS Sans Serif"
BEGIN
    GROUPBOX "Masks (per-vertex)", IDC_STATIC, 2, 2, 104, 98
    LTEXT    "Ch:",   IDC_STATIC,                                                  6,14,14,10
    CONTROL  "", IDC_MK_EDIT_TARGETCH,"CustEdit",      WS_TABSTOP,                 20,13,16,12
    CONTROL  "", IDC_MK_SPIN_TARGETCH,"SpinnerControl",WS_TABSTOP,                 36,13, 7,12
    LTEXT    "Contr:",IDC_STATIC,                                                 48,14,24,10
    CONTROL  "", IDC_MK_EDIT_CONTRAST,"CustEdit",      WS_TABSTOP,                 72,13,20,12
    CONTROL  "", IDC_MK_SPIN_CONTRAST,"SpinnerControl",WS_TABSTOP,                 92,13, 7,12

    LTEXT    "R", IDC_STATIC,                                                       6,31, 8,10
    COMBOBOX     IDC_MK_COMBO_SRCR,                                                14,29,40,80, CBS_DROPDOWNLIST|WS_TABSTOP
    CONTROL  "", IDC_MK_EDIT_WR, "CustEdit",       WS_TABSTOP,                     56,30,18,12
    CONTROL  "", IDC_MK_SPIN_WR, "SpinnerControl", WS_TABSTOP,                     74,30, 7,12
    CONTROL  "Inv", IDC_MK_CHK_INVR, "Button",BS_AUTOCHECKBOX|WS_TABSTOP,          84,31,22,10

    LTEXT    "G", IDC_STATIC,                                                       6,45, 8,10
    COMBOBOX     IDC_MK_COMBO_SRCG,                                                14,43,40,80, CBS_DROPDOWNLIST|WS_TABSTOP
    CONTROL  "", IDC_MK_EDIT_WG, "CustEdit",       WS_TABSTOP,                     56,44,18,12
    CONTROL  "", IDC_MK_SPIN_WG, "SpinnerControl", WS_TABSTOP,                     74,44, 7,12
    CONTROL  "Inv", IDC_MK_CHK_INVG, "Button",BS_AUTOCHECKBOX|WS_TABSTOP,          84,45,22,10

    LTEXT    "B", IDC_STATIC,                                                       6,59, 8,10
    COMBOBOX     IDC_MK_COMBO_SRCB,                                                14,57,40,80, CBS_DROPDOWNLIST|WS_TABSTOP
    CONTROL  "", IDC_MK_EDIT_WB, "CustEdit",       WS_TABSTOP,                     56,58,18,12
    CONTROL  "", IDC_MK_SPIN_WB, "SpinnerControl", WS_TABSTOP,                     74,58, 7,12
    CONTROL  "Inv", IDC_MK_CHK_INVB, "Button",BS_AUTOCHECKBOX|WS_TABSTOP,          84,59,22,10

    LTEXT    "Blur:", IDC_STATIC,                                                   6,73,20,10
    CONTROL  "", IDC_MK_EDIT_BLUR, "CustEdit",       WS_TABSTOP,                   26,72,16,12
    CONTROL  "", IDC_MK_SPIN_BLUR, "SpinnerControl", WS_TABSTOP,                   42,72, 7,12
    CONTROL  "Invert All", IDC_MK_CHK_INVERTALL, "Button",BS_AUTOCHECKBOX|WS_GROUP|WS_TABSTOP, 54,73,48,10

    CONTROL  "Overcrank", IDC_MK_CHK_OVERCRANK, "Button",BS_AUTOCHECKBOX|WS_GROUP|WS_TABSTOP, 6,87,50,10
    CONTROL  "Preview ch0", IDC_MK_CHK_PREVIEW, "Button",BS_AUTOCHECKBOX|WS_TABSTOP,         60,87,44,10
END
