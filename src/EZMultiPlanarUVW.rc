// EZMultiPlanarUVW.rc  —  108 DU wide
//
// Per-row block layout (57 DU per row, rows start at group y=2+12=14):
//   L1  base+0:  [x]N  Ch:[edit][spin]  [COMBOBOX  X+/X-/Y+/Y-/Z+/Z-]
//   L2  base+13: UT:[edit][spin]  VT:[edit][spin]
//   L3  base+27: UOff:[edit][spin]  VOff:[edit][spin]
//   L4  base+41: [x]Flip U  [x]Flip V  [x]Swap
//   DIV base+53: SS_GRAYRECT divider line
//
//   Row bases: 14  71  128  185  242  299
//   Proj rows group: y=2 h=358
//   Seam Options:    y=364 h=68
//   Blend Output:    y=436 h=72
//   Dialog height:   512

#include <winresrc.h>
#include "resource.h"

LANGUAGE LANG_NEUTRAL, SUBLANG_NEUTRAL

STRINGTABLE
BEGIN
    IDS_PARAMS  "Parameters"
    IDS_EN1  "En1"   IDS_CH1  "Ch1"   IDS_PR1  "Proj1"
    IDS_UT1  "UTile1"  IDS_VT1  "VTile1"  IDS_UOFF1 "UOff1"  IDS_VOFF1 "VOff1"
    IDS_FLIPU1 "FlipU1"  IDS_FLIPV1 "FlipV1"  IDS_SWAP1 "Swap1"
