    IDS_PARKU   "Park U"
    IDS_PARKV   "Park V"
    IDS_EN_BLEND "Enable Blend"
    IDS_CH_BLEND "Blend Channel"
    IDS_POWER    "Blend Power"
    IDS_SHOW     "Show Blend"
END

